                "runAfter": {
                    "Initialize_variables": [
                        "SUCCEEDED"
                    ]
                }
            },
            "Execute_a_SQL_query_(V2)": {
                "type": "ApiConnection",
                "inputs": {
                    "host": {
                        "connection": {
                            "referenceName": "sql-1"
                        }
                    },
                    "method": "post",
                    "body": {
                        "query": "Select 'Fact_Unit' Table_Name,case when count(*) >=100 then 'True' else 'False' end Load_Status from SCALAR.Fact_Unit\nWhere convert(date,SC_Insert_Date) = convert(date,getdate())\nUnion\nSelect 'Fact_LeaseRate' Table_Name,case when count(*) >=100 then 'True' else 'False' end Load_Status from SCALAR.Fact_LeaseRate\nWhere convert(date,SC_Insert_Date) = convert(date,getdate())\nUnion\nSelect 'Fact_Interchange' Table_Name,case when count(*) >=100 then 'True' else 'False' end Load_Status from SCALAR.Fact_Interchange\nWhere convert(date,SC_Insert_Date) = convert(date,getdate())\nUnion\nSelect 'Additional_Charges' Table_Name,case when count(*) >=100 then 'True' else 'False' end Load_Status from SCALAR.Additional_Charges\nWhere convert(date,SC_Insert_Date) = convert(date,getdate())"
                    },
                    "path": "/v2/datasets/@{encodeURIComponent(encodeURIComponent('default'))},@{encodeURIComponent(encodeURIComponent('default'))}/query/sql"
                },
                "runAfter": {
                    "Scope_Data_Sync": [
                        "SUCCEEDED"
                    ]
                }
            },
            "Filter_array": {
                "type": "Query",
                "inputs": {
                    "from": "@body('Execute_a_SQL_query_(V2)')?['ResultSets']?['Table1']",
                    "where": "@equals(toLower(item()?['Load_Status']),'false')"
                },
                "runAfter": {
                    "Execute_a_SQL_query_(V2)": [
                        "SUCCEEDED"
                    ]
                }
            },
            "Condition": {
                "type": "If",
                "expression": {
                    "and": [
                        {
                            "equals": [
                                "@length(body('Filter_array'))",
                                0
                            ]
                        }
                    ]
                },
                "actions": {
                    "Scope_Job_process": {
