{
    "definition": {
        "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
        "actions": {
            "Scope_Data_Sync": {
                "type": "Scope",
                "actions": {
                    "HTTP_Webhook-Asset_Data_Sync": {
                        "type": "HttpWebhook",
                        "inputs": {
                            "subscribe": {
                                "method": "POST",
                                "uri": "https://yuva-dev-function.azurewebsites.net/api/durabledatasync",
                                "body": {
                                    "callbackUrl": "@{listCallbackUrl()}",
                                    "processName": "Asset_Data_Sync"
                                },
                                "headers": {
                                    "Content-Type": "application/json",
                                    "x-functions-key": ""
                                }
                            }
                        },
                        "limit": {
                            "timeout": "PT31M"
                        }
                    },
                    "HTTP_Webhook-Session_Data_Sync": {
                        "type": "HttpWebhook",
                        "inputs": {
                            "subscribe": {
                                "method": "POST",
                                "uri": "https://yuva-dev-function.azurewebsites.net/api/durabledatasync",
                                "body": {
                                    "callbackUrl": "@{listCallbackUrl()}",
                                    "processName": "Session_Data_Sync"
                                },
                                "headers": {
                                    "Content-Type": "application/json",
                                    "x-functions-key": ""
                                }
                            }
                        },
                        "limit": {
                            "timeout": "PT31M"
                        }
                    },
                    "Check_if_data_sync_fails": {
                        "type": "If",
                        "expression": {
                            "and": [
                                {
                                    "equals": [
                                        "@body('HTTP_Webhook-Asset_Data_Sync')",
                                        "Asset sync successful"
                                    ]
                                }
                            ]
                        },
                        "actions": {},
                        "else": {
                            "actions": {
                                "Terminate_if_Asset_data_sync_failed": {
                                    "type": "Terminate",
                                    "inputs": {
                                        "runStatus": "Failed",
                                        "runError": {
                                            "code": "Asset Data Sync Failed",
                                            "message": "Asset Data Sync Failed"
                                        }
                                    },
                                    "runAfter": {
                                        "Call_workflow_in_this_logic_app-asset_sync_failed": [
                                            "SUCCEEDED"
                                        ]
                                    }
                                },
                                "Call_workflow_in_this_logic_app-asset_sync_failed": {
                                    "type": "Workflow",
                                    "inputs": {
                                        "host": {
                                            "workflow": {
                                                "id": "wf_dev_Notifications"
                                            }
                                        },
                                        "body": {
                                            "Execution Status": "Failed",
                                            "Recipients": "@join(variables('EmailRecipicients'),';')",
                                            "Job Failed": "Scalar",
                                            "Process Name": "Asset Data Sync",
                                            "Error Details": "@body('HTTP_Webhook-Asset_Data_Sync')",
                                            "Subject Line": "DEV - Scalar Job Failure: Asset Data Sync Failed"
                                        }
                                    }
                                }
                            }
                        },
                        "runAfter": {
                            "HTTP_Webhook-Asset_Data_Sync": [
                                "SUCCEEDED"
                            ]
                        }
                    },
                    "Check_if_session_data_sync_fails": {
                        "type": "If",
                        "expression": {
                            "and": [
                                {
                                    "equals": [
                                        "@trim(body('HTTP_Webhook-Session_Data_Sync'))",
                                        "Session sync successful"
                                    ]
                                }
                            ]
                        },
                        "actions": {},
                        "else": {
                            "actions": {
                                "Terminate_if_session_data_sync_failed": {
                                    "type": "Terminate",
                                    "inputs": {
                                        "runStatus": "Failed",
                                        "runError": {
                                            "code": "Session Data Sync Failed",
                                            "message": "Session Data Sync Failed"
                                        }
                                    },
                                    "runAfter": {
                                        "Call_workflow_in_this_logic_app-session_sync_failed": [
                                            "SUCCEEDED"
                                        ]
                                    }
                                },
                                "Call_workflow_in_this_logic_app-session_sync_failed": {
                                    "type": "Workflow",
                                    "inputs": {
                                        "host": {
                                            "workflow": {
                                                "id": "wf_dev_Notifications"
                                            }
                                        },
                                        "body": {
                                            "Execution Status": "Failed",
                                            "Recipients": "@join(variables('EmailRecipicients'),';')",
                                            "Job Failed": "Scalar",
                                            "Process Name": "Session Data Sync",
                                            "Error Details": "@body('HTTP_Webhook-Session_Data_Sync')",
                                            "Subject Line": "DEV - Scalar Job Failure: Session Data Sync Failed"
                                        }
                                    }
                                }
                            }
                        },
                        "runAfter": {
                            "HTTP_Webhook-Session_Data_Sync": [
                                "SUCCEEDED"
                            ]
                        }
                    },
                    "Call_workflow_in_this_logic_app-Asset": {
                        "type": "Workflow",
                        "inputs": {
                            "host": {
                                "workflow": {
                                    "id": "wf_dev_Notifications"
                                }
                            },
                            "body": {
                                "Execution Status": "Failed",
                                "Recipients": "@join(variables('EmailRecipicients'),';')",
                                "Job Failed": "Scalar",
                                "Process Name": "Asset Data Sync",
                                "Error Details": "@if(equals(actions('HTTP_Webhook-Asset_Data_Sync').status,'TimedOut'),\n'Asset Data Sync timed out while waiting for callback response',\ncoalesce(actions('HTTP_Webhook-Asset_Data_Sync').error.message,\n  'Asset Data Sync failed'))",
                                "Subject Line": "DEV - Scalar Job Failure: Asset Data Sync Failed"
                            }
                        },
                        "runAfter": {
                            "HTTP_Webhook-Asset_Data_Sync": [
                                "TIMEDOUT",
                                "FAILED"
                            ]
                        }
                    },
                    "Terminate_if_Asset_data_sync_timed_out": {
                        "type": "Terminate",
                        "inputs": {
                            "runStatus": "Failed",
                            "runError": {
                                "code": "Asset Data Sync Timed out",
                                "message": "Asset Data Sync Timed out"
                            }
                        },
                        "runAfter": {
                            "Call_workflow_in_this_logic_app-Asset": [
                                "SUCCEEDED"
                            ]
                        }
                    },
                    "Call_workflow_in_this_logic_app-Session": {
                        "type": "Workflow",
                        "inputs": {
                            "host": {
                                "workflow": {
                                    "id": "wf_dev_Notifications"
                                }
                            },
                            "body": {
                                "Execution Status": "Failed",
                                "Recipients": "@join(variables('EmailRecipicients'),';')",
                                "Job Failed": "Scalar",
                                "Process Name": "Session Data Sync",
                                "Error Details": "@if(equals(actions('HTTP_Webhook-Session_Data_Sync').status,'TimedOut'),\n'Session Data Sync timed out while waiting for callback response',\ncoalesce(actions('HTTP_Webhook-Session_Data_Sync').error.message,\n  'Session Data Sync failed'))",
                                "Subject Line": "DEV - Scalar Job Failure: Session Data Sync Failed"
                            }
